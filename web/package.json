{
  "name": "hermes-registry-web",
  "version": "0.1.0",
  "private": true,
  "description": "Web registry view for the Hermes agent package registry — browse and search skills, MCP servers, agents, workflows, and models.",
  "scripts": {
    "dev": "node scripts/gen-icons.mjs && next dev",
    "build": "node scripts/gen-icons.mjs && next build",
    "gen:icons": "node scripts/gen-icons.mjs",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:setup": "tsx scripts/migrate.ts && tsx scripts/seed.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@iconify/react": "^6.0.2",
    "drizzle-orm": "^0.38.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.469.0",
    "next": "15.1.7",
    "postgres": "^3.4.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^9.0.3",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@iconify/utils": "^3.1.3",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.30.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
