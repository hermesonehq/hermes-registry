{
  "schemaVersion": "1",
  "type": "mcp",
  "id": "sqlite",
  "name": "SQLite",
  "version": "1.1.0",
  "description": "Query and inspect a local SQLite database.",
  "author": {
    "name": "Model Context Protocol",
    "url": "https://github.com/modelcontextprotocol/servers"
  },
  "license": "MIT",
  "source": "https://github.com/modelcontextprotocol/servers-archived/tree/main/src/sqlite",
  "tags": [
    "database",
    "sql",
    "sqlite"
  ],
  "icon": "icon.svg",
  "compatibility": {
    "hermes": ">=0.3.0",
    "desktop": ">=0.6.0"
  },
  "permissions": [
    "filesystem:read",
    "filesystem:write"
  ],
  "transport": "stdio",
  "command": "uvx",
  "args": [
    "mcp-server-sqlite@2025.4.25"
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "db_path": {
        "type": "string",
        "description": "Path to the .sqlite file (appended as --db-path)."
      }
    },
    "required": [
      "db_path"
    ]
  }
}
