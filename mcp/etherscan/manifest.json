{
  "schemaVersion": "1",
  "type": "mcp",
  "id": "etherscan",
  "name": "Etherscan",
  "version": "1.0.0",
  "description": "Block explorer access — contract verification, transaction lookups, ABI fetch. Read-only, fine to leave on.",
  "author": { "name": "Community", "url": "https://docs.etherscan.io" },
  "source": "https://docs.etherscan.io",
  "tags": ["web3", "blockchain", "ethereum", "explorer"],
  "icon": "icon.svg",
  "compatibility": { "hermes": ">=0.3.0", "desktop": ">=0.6.0" },
  "permissions": ["network"],
  "transport": "stdio",
  "command": "npx",
  "args": ["-y", "etherscan-mcp"],
  "configSchema": {
    "type": "object",
    "properties": {
      "ETHERSCAN_API_KEY": {
        "type": "string",
        "description": "Etherscan API key, supplied as an env var."
      }
    },
    "required": ["ETHERSCAN_API_KEY"]
  }
}
